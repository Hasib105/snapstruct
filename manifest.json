{
  "manifest_version": 3,
  "name": "Lead Scraper AI",
  "description": "Scrape leads, products, companies, customers from any page with AI. Export to JSON/CSV.",
  "version": "0.2.0",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_title": "Lead Scraper AI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
